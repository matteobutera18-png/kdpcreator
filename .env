# ────────────────────────────────────────────────
#  KDP Factory Dashboard — Environment Variables
#  ⚠️  NON committare questo file su git!
# ────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# JWT — cambia questo segreto con uno tuo (min 32 caratteri)
JWT_SECRET=kdp_factory_super_secret_jwt_key_change_this_in_production_2024

# Sessione (quanto dura il token di login)
SESSION_EXPIRY=24h

# Percorso dati (relativo alla root del progetto)
DATA_DIR=server/data

# Ngrok (opzionale — per accesso da fuori rete locale)
# Registrati su https://ngrok.com e inserisci il tuo token
NGROK_AUTHTOKEN=

# Puppeteer (se vuoi usare il profilo Chrome esistente)
PUPPETEER_USER_DATA_DIR=
